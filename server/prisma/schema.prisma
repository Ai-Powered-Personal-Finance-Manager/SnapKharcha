generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String?
  googleId     String?    @unique
  avatar       String?
  refreshToken String?
  otp          String?
  otpExpiresAt DateTime?
  createdAt    DateTime   @default(now())
  budgets      Budget[]
  categories   Category[]
  expenses     Expense[]
}

model Category {
  id        String    @id @default(uuid())
  name      String
  userId    String
  deletedAt DateTime?
  icon      String?
  tags      String[]
  budgets   Budget[]
  user      User      @relation(fields: [userId], references: [id])
  expenses  Expense[]

  @@unique([name, userId, deletedAt])
}

model Budget {
  id           String   @id @default(uuid())
  amount       Float
  userId       String
  categoryId   String
  createdAt    DateTime @default(now())
  alert        Boolean?
  alertLimit   Decimal?
  expireDate   DateTime
  note         String?
  spendAmount  Float?
  startingDate DateTime
  category     Category @relation(fields: [categoryId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, categoryId])
}

model Expense {
  id         String    @id @default(uuid())
  amount     Float
  note       String?
  date       DateTime
  userId     String
  categoryId String?
  createdAt  DateTime  @default(now())
  category   Category? @relation(fields: [categoryId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}
