generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String?
  googleId     String?    @unique
  avatar       String?
  refreshToken String?
  otp          String?
  otpExpiresAt DateTime?
  createdAt    DateTime   @default(now())
  budgets      Budget[]
  categories   Category[]
  expenses     Expense[]
  income       Income[]
  loan         Loan[]
}

model Category {
  id        String    @id @default(uuid())
  name      String
  userId    String
  deletedAt DateTime?
  icon      String?
  tags      String[]
  color     String?
  budgets   Budget[]
  user      User      @relation(fields: [userId], references: [id])
  expenses  Expense[]
}

model Budget {
  id           String    @id @default(uuid())
  name         String
  amount       Int
  startingDate DateTime
  expireDate   DateTime
  spendAmount  Int?
  note         String?
  alert        Boolean   @default(false)
  alertLimit   Decimal?
  userId       String
  categoryId   String
  createdAt    DateTime  @default(now())
  category     Category  @relation(fields: [categoryId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
  expenses     Expense[]

  @@unique([userId, categoryId, startingDate])
  @@index([userId])
}

model Expense {
  id            String        @id @default(uuid())
  amount        Int
  note          String
  userId        String
  categoryId    String
  createdAt     DateTime      @default(now())
  budgetId      String
  date          DateTime      @default(now())
  merchant      String        @default("Unknown")
  paymentMethod PaymentMethod @default(CASH)
  budget        Budget        @relation(fields: [budgetId], references: [id])
  category      Category      @relation(fields: [categoryId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([budgetId])
}

model Loan {
  id           String     @id @default(uuid())
  name         String
  lenderName   String
  interestRate Decimal    @db.Decimal(5, 2)
  amount       Int
  emiAmount    Int
  paidAmount   Int        @default(0)
  note         String?
  userId       String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  timeUnit     TimeUnit
  timeValue    Int
  status       StatusType
  user         User       @relation(fields: [userId], references: [id])
}

model Income {
  id        String      @id @default(uuid())
  amount    Int
  company   String
  position  String
  source    String
  note      String?
  type      IncomeType
  userId    String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  creditDay Int?
  status    IncomeStaus
  user      User        @relation(fields: [userId], references: [id])
}

enum PaymentMethod {
  CASH
  WALLET
  BANK
}

enum TimeUnit {
  MONTH
  YEAR
}

enum StatusType {
  ACTIVE
  PAID
}

enum IncomeType {
  FIXED
  VARIABLE
}

enum IncomeStaus {
  ACTIVE
  PAUSED
}


